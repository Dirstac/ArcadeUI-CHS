    PUSHBUTTON      "取消",IDCANCEL,98,114,50,14
END

IDD_COLUMNS DIALOGEX 0, 0, 302, 146
STYLE WS_POPUP | WS_VISIBLE | WS_CAPTION | WS_SYSMENU | DS_MODALFRAME | DS_SETFONT
CAPTION "自定义栏目"
FONT 9, "Tahoma"
BEGIN
    LTEXT           "可用栏目:",IDC_STATIC,6,4,80,10,SS_CENTERIMAGE
    CONTROL         "",IDC_LISTAVAILABLECOLUMNS,WC_LISTVIEW,LVS_REPORT | LVS_SINGLESEL | LVS_NOCOLUMNHEADER | LVS_NOSORTHEADER | LVS_SHOWSELALWAYS | WS_BORDER | WS_TABSTOP,6,16,90,100
    PUSHBUTTON      "添加 ->",IDC_BUTTONADD,102,16,46,14,WS_DISABLED
    PUSHBUTTON      "<- 移除",IDC_BUTTONREMOVE,102,34,46,14,WS_DISABLED
    LTEXT           "按此顺序显示这些栏目:",IDC_STATIC,154,4,116,10,SS_CENTERIMAGE
    CONTROL         "",IDC_LISTSHOWCOLUMNS,WC_LISTVIEW,LVS_REPORT | LVS_SINGLESEL | LVS_NOCOLUMNHEADER | LVS_NOSORTHEADER | LVS_SHOWSELALWAYS | WS_BORDER | WS_TABSTOP,154,16,90,100
    PUSHBUTTON      "向上",IDC_BUTTONMOVEUP,250,16,46,14,WS_DISABLED
    PUSHBUTTON      "向下",IDC_BUTTONMOVEDOWN,250,34,46,14,WS_DISABLED
    DEFPUSHBUTTON   "确定",IDOK,98,124,50,14
    PUSHBUTTON      "取消",IDCANCEL,154,124,50,14
END

