//
// Menu
//

IDR_UI_MENU MENU 
BEGIN
    POPUP "文件(&F)"
    BEGIN
        MENUITEM "运行\tAlt+O",                         ID_FILE_PLAY
        MENUITEM SEPARATOR
        MENUITEM "播放 INP 录像\tAlt+F1",                   ID_FILE_PLAY_BACK
        MENUITEM "播放 WAV 音频\tAlt+F2",                   ID_PLAY_AUDIO
        MENUITEM "播放 MNG 视频\tAlt+F3",                   ID_PLAY_MNG
        MENUITEM "播放 AVI 视频\tAlt+F5",                   ID_PLAY_VIDEO
        MENUITEM SEPARATOR
        MENUITEM "录制 INP 录像\tCtrl+F1",   ID_FILE_PLAY_RECORD
        MENUITEM "录制 WAV 音频\tCtrl+F2",         ID_FILE_PLAY_RECORD_WAVE
        MENUITEM "录制 MNG 视频\tCtrl+F3",         ID_FILE_PLAY_RECORD_MNG
        MENUITEM "录制 AVI 视频\tCtrl+F5",         ID_FILE_PLAY_RECORD_AVI
        MENUITEM SEPARATOR
        MENUITEM "载入游戏存档\tAlt+F7",         ID_FILE_LOADSTATE
        MENUITEM SEPARATOR
        MENUITEM "退出\t Alt+F4",                          ID_FILE_EXIT
    END
    POPUP "查看(&V)"
    BEGIN
        MENUITEM "工具栏\tAlt+T",                      ID_VIEW_TOOLBARS
        MENUITEM "状态栏\tAlt+S",                      ID_VIEW_STATUS
        MENUITEM "分类区\tAlt+F",                 ID_VIEW_FOLDERS
        MENUITEM "图片区\tAlt+P",                ID_VIEW_PICTURE_AREA
        MENUITEM "标签栏\tAlt+B",                          ID_VIEW_PAGETAB
        MENUITEM SEPARATOR
        MENUITEM "大图标\tCtrl+L",                   ID_VIEW_ICONS_LARGE
        MENUITEM "小图标\tCtrl+S",                 ID_VIEW_ICONS_SMALL        
        MENUITEM SEPARATOR
        MENUITEM "分组显示\tCtrl+G",                     ID_ENABLE_INDENT        
        MENUITEM SEPARATOR
        POPUP "按游戏列表排序"
        BEGIN
            MENUITEM "游戏描述\tAlt+1",              ID_VIEW_BYGAME
            MENUITEM "游戏名称\tAlt+2",                 ID_VIEW_BYDIRECTORY
            MENUITEM "游戏原作\tAlt+3",                ID_VIEW_BYSOURCE
            MENUITEM "开发厂商\tAlt+4",             ID_VIEW_BYMANUFACTURER
            MENUITEM "发行时间\tAlt+5",                     ID_VIEW_BYYEAR
            MENUITEM "游戏次数\tAlt+6",            ID_VIEW_BYTIMESPLAYED
        END
        MENUITEM SEPARATOR
        POPUP "显示文件夹"
        BEGIN
            MENUITEM "overridden by code",                ID_SHOW_FOLDER_START
        END
        MENUITEM SEPARATOR
        POPUP "显示图片"
        BEGIN
            MENUITEM "快照",                              ID_TOGGLE_TAB_SCREENSHOT
            MENUITEM "标题",                             ID_TOGGLE_TAB_TITLE
            MENUITEM "得分",                            ID_TOGGLE_TAB_SCORES
            MENUITEM "帮助",                            ID_TOGGLE_TAB_HOWTO
            MENUITEM "选角",                            ID_TOGGLE_TAB_SELECT
            MENUITEM "对阵",                            ID_TOGGLE_TAB_VERSUS
            MENUITEM "BOSS",                            ID_TOGGLE_TAB_BOSSES
            MENUITEM "结局",                                ID_TOGGLE_TAB_ENDS
            MENUITEM "游戏结束",                        ID_TOGGLE_TAB_GAMEOVER
            MENUITEM "徽标",                             ID_TOGGLE_TAB_LOGO
            MENUITEM "插图",                         ID_TOGGLE_TAB_ARTWORK
            MENUITEM "封面",                             ID_TOGGLE_TAB_FLYER
            MENUITEM "机台",                           ID_TOGGLE_TAB_CABINET
            MENUITEM "贴图",                           ID_TOGGLE_TAB_MARQUEE
            MENUITEM "操作台",                     ID_TOGGLE_TAB_CONTROL_PANEL
            MENUITEM "电路板",                               ID_TOGGLE_TAB_PCB
            MENUITEM "历史",                               ID_TOGGLE_TAB_HISTORY
        END
	    MENUITEM SEPARATOR
 	    MENUITEM "中文游戏列表", 				       ID_CHINESE_GAMELIST // 缘来是你 USE_CLIST
        MENUITEM SEPARATOR
        MENUITEM "全屏模式\tF11",                     ID_VIEW_FULLSCREEN
    END
    POPUP "选项(&O)"
    BEGIN
        MENUITEM "界面设置\tCtrl+I",           ID_OPTIONS_INTERFACE
        MENUITEM "游戏选项\tCtrl+O",        ID_OPTIONS_DEFAULTS
        MENUITEM "目录设置\tCtrl+D",                 ID_OPTIONS_DIR
        MENUITEM SEPARATOR
        POPUP "字体/颜色"
        BEGIN
            MENUITEM "文件夹列表字体/颜色\tCtrl+1",        ID_OPTIONS_TREE_FONT
            MENUITEM "游戏列表字体/颜色\tCtrl+2",       ID_OPTIONS_FONT
            MENUITEM "游戏图片字体/颜色\tCtrl+3",       ID_OPTIONS_HISTORY_FONT
            MENUITEM "文件夹列表背景颜色\tCtrl+4",     ID_OPTIONS_FOLDERS_COLOR
            MENUITEM "游戏列表背景颜色\tCtrl+5",     ID_OPTIONS_LIST_COLOR
            MENUITEM "游戏图像背景颜色\tCtrl+6",     ID_OPTIONS_HISTORY_COLOR
        END
        MENUITEM SEPARATOR
        MENUITEM "恢复默认选项\tCtrl+R",   ID_OPTIONS_RESET_DEFAULTS
    END
    POPUP "工具(&T)"
    BEGIN
        MENUITEM "随机选择游戏\tAlt+R",              ID_CONTEXT_SELECT_RANDOM
        MENUITEM SEPARATOR
        MENUITEM "游戏过滤器\tCtrl+F",              ID_CONTEXT_FILTERS
        MENUITEM "自定义栏目\tCtrl+C",             ID_CUSTOMIZE_FIELDS
        MENUITEM SEPARATOR
        MENUITEM "校验所有游戏",                      ID_FILE_AUDIT
        MENUITEM "刷新游戏列表\tF5",               ID_UPDATE_GAMELIST
        MENUITEM SEPARATOR
        MENUITEM "保存游戏描述列表\tAlt+F8",        ID_FILE_GAMELIST
        MENUITEM "保存游戏名称列表\tAlt+F9",      ID_FILE_ROMSLIST
    END
    POPUP "帮助(&H)"
    BEGIN
//============================= 缘来是你 ============================>>>
    	MENUITEM "导出所有组集",                ID_TOOLS_EXPORT_ALL
	MENUITEM "导出完整组集",                ID_TOOLS_EXPORT_COMPLETE
	MENUITEM "导出缺失组集",                ID_TOOLS_EXPORT_MISSING
	MENUITEM SEPARATOR
	MENUITEM "导出当前列表",                ID_TOOLS_EXPORT_CURRENT
	MENUITEM SEPARATOR
//===================================================================>>>
//        MENUITEM "Online Manual\tF1",                      ID_HELP_CONTENTS
//        MENUITEM "Support Forum\tF3",                       ID_HELP_TROUBLE
        MENUITEM "支持论坛",                       ID_HELP_TROUBLE
//        MENUITEM SEPARATOR
//        MENUITEM "Mame release notes\tF6",              ID_HELP_WHATS_NEW
//        MENUITEM SEPARATOR
//        MENUITEM "MAME development site\tF7",             ID_MAME_HOMEPAGE
//        MENUITEM "Frequently Asked Questions\tF8",         ID_MAME_FAQ
        MENUITEM SEPARATOR
//        MENUITEM "About\tF9",                            ID_HELP_ABOUT
        MENUITEM "关于",                            ID_HELP_ABOUT
    END
END

IDR_CONTEXT_MENU MENU
BEGIN
    POPUP "Context Menu"
    BEGIN
        MENUITEM "运行游戏\tAlt+O",                           ID_FILE_PLAY
		MENUITEM "IPS\tAlt+P",                         		 ID_PLAY_IPS	//缘来是你 IPS
        MENUITEM SEPARATOR
        MENUITEM "指令录像\tCtrl+F1",          ID_FILE_PLAY_RECORD
        MENUITEM "读取存档\tAlt+F7",                ID_FILE_LOADSTATE
        MENUITEM SEPARATOR
        MENUITEM "收藏游戏\tAlt+W",           ID_CONTEXT_ADD_CUSTOM
        MENUITEM "取消收藏\tAlt+X",        ID_CONTEXT_REMOVE_CUSTOM
//=============================== 缘来是你 ====================================>>>
	MENUITEM SEPARATOR
        MENUITEM "删除 ROM 文件\tDel",                         ID_CONTEXT_DELETE_ROM
	MENUITEM "批量删除模式\tCtrl+Alt+D",                   ID_CONTEXT_BATCH_DELETE_MODE
	MENUITEM "删除选中的 ROM 文件\tDel",                   ID_CONTEXT_DELETE_SELECTED_ROMS
        MENUITEM SEPARATOR
        MENUITEM "全选\tCtrl+A",                     ID_CONTEXT_SELECT_ALL
        MENUITEM "全部取消\tCtrl+Z",                 ID_CONTEXT_SELECT_NONE
//================================================================================>>>
        MENUITEM SEPARATOR
        MENUITEM "游戏信息\tAlt+I",                    ID_GAME_INFO
        MENUITEM "校验游戏\tAlt+A",                          ID_GAME_AUDIT
        MENUITEM SEPARATOR
        MENUITEM "重置游戏次数\tAlt+V",            ID_CONTEXT_RESET_PLAYCOUNT
        MENUITEM "重置游戏时间\tAlt+Y",              ID_CONTEXT_RESET_PLAYTIME
        MENUITEM SEPARATOR
        MENUITEM "播放演示视频\tCtrl+M",  ID_VIDEO_SNAP
        MENUITEM "阅读PDF说明",                   ID_MANUAL
        MENUITEM "打开信息文件",                  ID_NOTEPAD
//        MENUITEM "Delete game settings",                  ID_RC_CLEAN
        MENUITEM "播放游戏声音\tAlt+M",      ID_PLAY_M1
        MENUITEM SEPARATOR
        MENUITEM "游戏属性\tAlt+G",                     ID_GAME_PROPERTIES
        MENUITEM "驱动属性\tAlt+D",          ID_FOLDER_SOURCEPROPERTIES
        MENUITEM SEPARATOR
        MENUITEM "查看ZIP文件\tAlt+Z",          ID_VIEW_ZIP
    END
END

IDR_CONTEXT_HEADER MENU
BEGIN
    POPUP "Header Context Menu"
    BEGIN
        MENUITEM "按升序排列\tAlt+UP",               ID_SORT_ASCENDING
        MENUITEM "按降序排列\tAlt+DOWN",            ID_SORT_DESCENDING
        MENUITEM SEPARATOR
        MENUITEM "自定义栏目\tCtrl+C",              ID_CUSTOMIZE_FIELDS
    END
END

IDR_CONTEXT_TREE MENU
