IDD_PROP_IPS DIALOGEX 0, 0, 400, 280
STYLE DS_SETFONT | DS_MODALFRAME | WS_POPUP | WS_VISIBLE | WS_CAPTION | WS_SYSMENU
CAPTION "IPS 管理器"
FONT 9, "Tahoma", 0, 0, 0x0
BEGIN
    LTEXT           "选择 IPS 补丁:", IDC_STATIC, 10, 10, 60, 8
    CONTROL         "", IDC_IPS_TREE, "SysTreeView32", TVS_HASBUTTONS | TVS_HASLINES | TVS_LINESATROOT | TVS_CHECKBOXES | WS_BORDER | WS_TABSTOP, 10, 22, 200, 230
    
    LTEXT           "预览:", IDC_STATIC, 220, 10, 30, 8
    CONTROL         "", IDC_IPS_SNAP, "Static", SS_BITMAP | SS_CENTERIMAGE | WS_BORDER, 220, 22, 170, 120
    
    LTEXT           "描述:", IDC_STATIC, 220, 148, 30, 8
    EDITTEXT        IDC_IPS_DESC, 220, 158, 170, 94, ES_MULTILINE | ES_READONLY | WS_VSCROLL
    
    LTEXT           "语言:", IDC_STATIC, 10, 261, 30, 8
    COMBOBOX        IDC_IPS_LANG, 40, 258, 80, 100, CBS_DROPDOWNLIST | WS_VSCROLL | WS_TABSTOP
    
    AUTOCHECKBOX    "强制关联", IDC_IPS_RELATION, 130, 260, 60, 10
    
    PUSHBUTTON      "清理", IDC_IPS_CLEAR, 220, 258, 50, 14
    DEFPUSHBUTTON   "确定", IDOK, 280, 258, 50, 14
    PUSHBUTTON      "取消", IDCANCEL, 340, 258, 50, 14
END
