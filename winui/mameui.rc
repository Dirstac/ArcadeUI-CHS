/////////////////////////////////////////////////////////////////////////////
//
// Dialog
//

IDD_STARTUP DIALOGEX 0, 0, 263, 86
STYLE WS_POPUP | WS_VISIBLE | WS_BORDER | DS_CENTER | DS_SETFOREGROUND | DS_SETFONT
EXSTYLE WS_EX_TOOLWINDOW
FONT 10, "Tahoma"
BEGIN
    CONTROL         "",IDC_SPLASH,WC_STATIC,SS_BITMAP,0,0,56,18
    CTEXT           "",IDC_STATIC,0,69,262,12
    CTEXT           "",IDC_PROGBAR,0,77,262,12
END

IDD_MAIN DIALOGEX 0, 0, 364, 206
STYLE WS_POPUP | WS_OVERLAPPEDWINDOW | WS_CLIPCHILDREN | WS_CLIPSIBLINGS | DS_NOFAILCREATE | DS_SETFOREGROUND | DS_SETFONT
EXSTYLE WS_EX_CONTROLPARENT
CAPTION "MAMEUI - 运行时覆盖"
CLASS "MainClass"
FONT 9, "Tahoma"
BEGIN
    CONTROL         "",IDC_DIVIDER,WC_STATIC,SS_ETCHEDHORZ,0,0,364,1
    CONTROL         "",IDC_TREE,WC_TREEVIEW,TVS_HASBUTTONS | TVS_TRACKSELECT | TVS_LINESATROOT | TVS_EDITLABELS | TVS_FULLROWSELECT | TVS_SHOWSELALWAYS | WS_BORDER | WS_TABSTOP,5,28,48,172
    CONTROL         "",IDC_LIST,WC_LISTVIEW,LVS_REPORT | LVS_SINGLESEL | LVS_SHOWSELALWAYS | LVS_SHAREIMAGELISTS | WS_BORDER | WS_TABSTOP,65,28,42,172
    GROUPBOX        "",IDC_SPLITTER,55,28,8,172,BS_NOTIFY | NOT WS_VISIBLE
    GROUPBOX        "",IDC_SPLITTER2,109,28,8,172,BS_NOTIFY | NOT WS_VISIBLE
    CONTROL         "",IDC_SSBORDER,WC_STATIC,SS_GRAYFRAME,121,28,176,172
    CONTROL         "",IDC_SSFRAME,WC_STATIC,SS_NOTIFY,121,28,176,172
    CONTROL         "",IDC_SSPICTURE,WC_STATIC,SS_BITMAP,141,18,141,127
    EDITTEXT        IDC_HISTORY,129,150,167,49,ES_MULTILINE | ES_READONLY | NOT WS_BORDER | WS_VSCROLL
END

IDD_ABOUT DIALOGEX 0, 0, 320, 186
STYLE WS_POPUP | WS_VISIBLE | WS_BORDER | DS_SETFONT
FONT 9, "Tahoma"
BEGIN
    RTEXT            "",IDC_BUILD,6,4,308,10
    LTEXT            "",IDC_BUILDVER,6,4,120,10
    CONTROL         "",IDC_ABOUT,WC_STATIC,SS_BITMAP,6,16,56,17
    CTEXT           "MAME 版权所有 （C） 1997-2026 MAME 贡献者",IDC_TEXT1,6,106,310,10
    CTEXT           "由 Christopher Kirmse 和 MAMEUI 团队制作的 MAMEUI 版本",IDC_TEXT2,6,118,310,10
    CTEXT           "额外 MAMEUI 代码由 Mike Haaland, Andrew Kirmse,",IDC_TEXT3,6,130,310,10
    CTEXT           "Jeff Miller, John Hardy IV 和 Michael Soderstrom 编写",IDC_TEXT4,6,142,310,10
    CTEXT           "Mamesick 和 Robbbert 提供其他 MAMEUIFX 代码和功能",IDC_SICKFX,6,154,310,10
    DEFPUSHBUTTON   "确定",IDOK,136,166,50,14
END

IDD_AUDIT DIALOGEX 0, 0, 284, 388
STYLE WS_POPUP | WS_VISIBLE | WS_CAPTION | WS_SYSMENU | DS_MODALFRAME | DS_SETFONT
CAPTION "文件校验"
FONT 9, "Tahoma"
BEGIN
    GROUPBOX        "结果",IDC_STATIC,6,4,272,80
    CONTROL         "",IDC_ROMS_PROGRESS,PROGRESS_CLASS,0,12,14,260,10
    LTEXT           "正确:",IDC_STATIC,12,28,36,10
    LTEXT           "错误:",IDC_STATIC,12,42,36,10
    LTEXT           "丢失:",IDC_STATIC,12,56,36,10
    LTEXT           "总计:",IDC_STATIC,12,70,36,10
    LTEXT           "0",IDC_ROMS_CORRECT,52,28,20,10
    LTEXT           "0",IDC_ROMS_INCORRECT,52,42,20,10
    LTEXT           "0",IDC_ROMS_NOTFOUND,52,56,20,10
    LTEXT           "0",IDC_ROMS_TOTAL,52,70,20,10
    GROUPBOX        "详细信息",IDC_STATIC,6,88,272,92
    EDITTEXT        IDC_AUDIT_DETAILS,12,100,260,262,ES_MULTILINE | WS_BORDER | WS_VSCROLL | NOT WS_TABSTOP
    DEFPUSHBUTTON   "取消",IDCANCEL,116,368,50,14
END

IDD_DIRECTORIES DIALOGEX 0, 0, 230, 307
STYLE WS_POPUP | WS_VISIBLE | WS_CAPTION | WS_SYSMENU | DS_MODALFRAME | DS_SETFONT
CAPTION "目录"
FONT 9, "Tahoma"
BEGIN
    LTEXT           "显示目录:",IDC_STATIC,6,4,68,10
    COMBOBOX        IDC_DIR_COMBO,6,16,160,82,CBS_DROPDOWNLIST | WS_VSCROLL | WS_TABSTOP
    LTEXT           "目录:",IDC_STATIC,6,38,38,10
    CONTROL         "",IDC_DIR_LIST,WC_LISTVIEW,LVS_REPORT | LVS_SINGLESEL | LVS_SHOWSELALWAYS | LVS_EDITLABELS | LVS_NOSORTHEADER | LVS_NOCOLUMNHEADER | WS_BORDER | WS_TABSTOP,6,50,160,251
    DEFPUSHBUTTON   "确定",IDOK,174,4,50,14
    PUSHBUTTON      "取消",IDCANCEL,174,22,50,14
    PUSHBUTTON      "浏览...",IDC_DIR_BROWSE,174,50,50,14
    PUSHBUTTON      "插入",IDC_DIR_INSERT,174,68,50,14
    PUSHBUTTON      "删除",IDC_DIR_DELETE,174,86,50,14
END

IDD_GAME_INFO DIALOGEX 0, 0, 220, 294
